# Dimension
#---------------------------------------------------

set dimension = 3

#---------------------------------------------------
# Simulation and IO Control
#---------------------------------------------------

subsection simulation control
  set time step         = 2.81609e-07
  set time end          = 0.6535526695296636   
  set log frequency     = 9000
  set output frequency  = 45000
  set output path       = ./out_TI6AL4V-45-106_2025-04-01/
  set output boundaries = false
end

#---------------------------------------------------
# Timer
#---------------------------------------------------

subsection timer
   set type = iteration
end

#---------------------------------------------------
# Restart
#---------------------------------------------------

subsection restart
  # Checkpointing parameters
  set checkpoint = true
  set frequency  = 500000

  # Output/input files
  set filename   = restart_TI6AL4V-45-106_2025-04-01

  # Restarting parameters
  set restart    = false
end

#---------------------------------------------------
# Model parameters
#---------------------------------------------------
subsection model parameters
  subsection contact detection
    set contact detection method                = dynamic
    set neighborhood threshold                  = 1.15
    set dynamic contact search size coefficient = 0.85
    set frequency                               = 1
  end
  
  subsection load balancing 
    set load balance method      = frequent
    set frequency                = 25000
    set dynamic check frequency  = 25000
    set threshold                = 0.5
    set step                     = 1
    #set particle weight          = 0
    subsection cell weight function
    #  set Function expression = if(y>-0.002, if(y<0.012,20000,1000),1000)
    end
  end
  
  set dmt cut-off threshold = 0.1
  set particle particle contact force method  = DMT
  set particle wall contact force method      = DMT
  set rolling resistance torque method        = epsd_resistance
  set f coefficient                           = 0.1
  set integration method                      = velocity_verlet
  
end 
#---------------------------------------------------
# Physical Properties
#---------------------------------------------------
